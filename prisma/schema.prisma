generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  customer
}

enum BlacklistSource {
  manual
  import
  provider
}

enum SmsCampaignTargetType {
  phonebook
  paste
}

enum SmsCampaignStatus {
  queued
  running
  paused
  completed
  failed
  canceled
}

enum SmsMessageType {
  bulk
  individual
  otp
}

enum SmsMessageStatus {
  queued
  sent
  delivered
  failed
  waiting
  skipped
}

enum SmsCreditTransactionType {
  add
  deduct
  refund
  adjustment
  reserve
  release
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  passwordHash       String
  name               String
  role               UserRole @default(customer)
  isActive           Boolean  @default(true)
  smsCreditBalance   Decimal  @default(0) @db.Decimal(18, 4)
  smsMarkupPercent   Decimal  @default(0) @db.Decimal(5, 2)
  defaultProviderId  String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  defaultProvider      SmsProvider?            @relation("UserDefaultProvider", fields: [defaultProviderId], references: [id])
  smsPhoneBooks        SmsPhoneBook[]
  smsContacts          SmsContact[]
  smsBlacklistEntries  SmsBlacklist[]
  smsCampaigns         SmsCampaign[]
  smsMessages          SmsMessage[]
  smsCreditTransactions SmsCreditTransaction[] @relation("CreditOwner")
  createdCreditLogs    SmsCreditTransaction[]  @relation("CreditCreator")
  auditLogs            AuditLog[]
  otpHistory           SmsOtpHistory[]
  updatedSystemSettings SystemSetting[]       @relation("SettingsUpdatedBy")
  accounts             Account[]
  sessions             Session[]

  @@index([role, isActive])
}

model SmsProvider {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  baseUrl        String
  tokenEncrypted String
  isActive       Boolean  @default(true)
  priority       Int      @default(100)
  timeoutSeconds Int      @default(15)
  dailyLimit     Int?
  hourlyLimit    Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  usersWithDefault User[]                 @relation("UserDefaultProvider")
  campaigns        SmsCampaign[]
  messages         SmsMessage[]
  prices           SmsProviderPriceCache[]
  otpHistory       SmsOtpHistory[]

  @@index([isActive, priority])
}

model SmsPhoneBook {
  id               String   @id @default(cuid())
  userId           String
  name             String
  description      String?
  totalCount       Int      @default(0)
  validCount       Int      @default(0)
  invalidCount     Int      @default(0)
  blacklistedCount Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  contacts  SmsContact[]
  campaigns SmsCampaign[]

  @@unique([userId, name])
  @@index([userId, createdAt])
}

model SmsContact {
  id           String   @id @default(cuid())
  userId       String
  phoneBookId  String
  phoneRaw     String
  phoneE164    String?
  countryCode  String?
  isValid      Boolean  @default(false)
  isBlacklisted Boolean @default(false)
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  phoneBook SmsPhoneBook @relation(fields: [phoneBookId], references: [id], onDelete: Cascade)

  @@unique([phoneBookId, phoneE164])
  @@index([userId, phoneBookId, isValid])
}

model SmsBlacklist {
  id        String          @id @default(cuid())
  userId    String?
  phoneE164 String
  reason    String?
  source    BlacklistSource @default(manual)
  createdAt DateTime        @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, phoneE164])
  @@index([phoneE164])
  @@index([userId, createdAt])
}

model SmsCampaign {
  id               String             @id @default(cuid())
  userId           String
  providerId       String
  name             String
  origin           String
  message          String
  targetType       SmsCampaignTargetType
  phoneBookId      String?
  status           SmsCampaignStatus  @default(queued)
  totalCount       Int                @default(0)
  queuedCount      Int                @default(0)
  sentCount        Int                @default(0)
  deliveredCount   Int                @default(0)
  failedCount      Int                @default(0)
  waitingCount     Int                @default(0)
  skippedCount     Int                @default(0)
  costReserved     Decimal            @default(0) @db.Decimal(18, 4)
  costFinal        Decimal            @default(0) @db.Decimal(18, 4)
  providerReportId String?
  createdAt        DateTime           @default(now())
  startedAt        DateTime?
  completedAt      DateTime?
  updatedAt        DateTime           @updatedAt

  user               User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider           SmsProvider            @relation(fields: [providerId], references: [id])
  phoneBook          SmsPhoneBook?          @relation(fields: [phoneBookId], references: [id], onDelete: SetNull)
  messages           SmsMessage[]
  creditTransactions SmsCreditTransaction[]

  @@index([userId, status, createdAt])
  @@index([providerId, status, createdAt])
}

model SmsMessage {
  id                String           @id @default(cuid())
  userId            String
  campaignId        String?
  providerId        String
  type              SmsMessageType
  phoneE164         String
  message           String
  origin            String
  status            SmsMessageStatus @default(queued)
  providerReportId  String?
  providerMessageId String?
  error             String?
  cost              Decimal          @default(0) @db.Decimal(18, 4)
  sentAt            DateTime?
  deliveredAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  user               User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign           SmsCampaign?           @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  provider           SmsProvider            @relation(fields: [providerId], references: [id])
  creditTransactions SmsCreditTransaction[]

  @@index([userId, status, createdAt])
  @@index([campaignId, status])
  @@index([providerId, status, createdAt])
}

model SmsCreditTransaction {
  id               String                   @id @default(cuid())
  userId           String
  type             SmsCreditTransactionType
  amount           Decimal                  @db.Decimal(18, 4)
  balanceBefore    Decimal                  @db.Decimal(18, 4)
  balanceAfter     Decimal                  @db.Decimal(18, 4)
  reason           String?
  relatedCampaignId String?
  relatedMessageId String?
  createdById      String?
  createdAt        DateTime                 @default(now())

  user           User        @relation("CreditOwner", fields: [userId], references: [id], onDelete: Cascade)
  relatedCampaign SmsCampaign? @relation(fields: [relatedCampaignId], references: [id], onDelete: SetNull)
  relatedMessage SmsMessage?   @relation(fields: [relatedMessageId], references: [id], onDelete: SetNull)
  createdBy      User?       @relation("CreditCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([relatedCampaignId])
  @@index([relatedMessageId])
}

model SmsProviderPriceCache {
  id          String   @id @default(cuid())
  providerId  String
  countryCode String
  price       Decimal  @db.Decimal(18, 6)
  currency    String?
  raw         Json
  updatedAt   DateTime @updatedAt

  provider SmsProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, countryCode])
  @@index([providerId, updatedAt])
}

model SmsOtpHistory {
  id               String   @id @default(cuid())
  userId           String
  providerId       String
  phoneE164        String
  codeHash         String?
  status           String
  providerReportId String?
  cost             Decimal  @default(0) @db.Decimal(18, 4)
  createdAt        DateTime @default(now())
  deliveredAt      DateTime?
  expiresAt        DateTime?

  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider SmsProvider @relation(fields: [providerId], references: [id])

  @@index([userId, createdAt])
  @@index([providerId, status, createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([entityType, entityId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  type        String?
  description String?
  updatedById String?
  updatedAt   DateTime @updatedAt

  updatedBy User? @relation("SettingsUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
}
